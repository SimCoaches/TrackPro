# TrackPro Environment Configuration Example
# Copy this file to .env and fill in your actual credentials
# The .env file should never be committed to version control

# ================================================================================================
# SUPABASE CONFIGURATION - Cloud Database & Authentication
# ================================================================================================
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# ================================================================================================
# TWILIO CONFIGURATION - SMS-based Two-Factor Authentication
# ================================================================================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid_here

# ================================================================================================
# AI COACH CONFIGURATION - OpenAI & ElevenLabs
# ================================================================================================
# OpenAI API Key for AI coaching features (starts with 'sk-')
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ElevenLabs API Key for text-to-speech (starts with a random string)
# Get your key from: https://elevenlabs.io/docs/api-reference/authentication
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ================================================================================================
# STRIPE CONFIGURATION - Payment Processing
# ================================================================================================
# Stripe Secret Key for payment processing (starts with 'sk_')
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Stripe Publishable Key for frontend integration (starts with 'pk_')
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# ================================================================================================
# DEVELOPMENT & DEBUG SETTINGS
# ================================================================================================
# Force enable/disable Supabase integration
TRACKPRO_FORCE_SUPABASE=false

# Force enable/disable Twilio integration
TRACKPRO_FORCE_TWILIO=false

# Enable debug mode for Supabase operations
TRACKPRO_SUPABASE_DEBUG=false

# Enable debug mode for Twilio operations
TRACKPRO_TWILIO_DEBUG=false
